{
  "schema_version": 1,
  "baseline_date": "2026-03-03",
  "policy": {
    "pinning": "exact",
    "scope": "current flows only (legacy excluded)",
    "status_model": "single canonical pinned set"
  },
  "drift_exceptions": {
    "npm": {
      "@mysten/sui": "Latest 2.x breaks current import surface used in docs/examples; upgrade after migration."
    }
  },
  "sdk_versions": {
    "npm": {
      "@switchboard-xyz/on-demand": "3.9.0",
      "@switchboard-xyz/common": "5.7.0",
      "@switchboard-xyz/on-demand-solidity": "1.1.0",
      "@switchboard-xyz/sui-sdk": "0.1.14",
      "@switchboard-xyz/aptos-sdk": "0.1.5",
      "@switchboard-xyz/iota-sdk": "0.0.3"
    },
    "crates": {
      "switchboard-on-demand": "0.11.3",
      "switchboard-protos": "0.2.4"
    }
  },
  "companion_versions": {
    "npm": {
      "@solana/web3.js": "1.98.4",
      "@mysten/sui": "1.38.0",
      "@aptos-labs/ts-sdk": "6.1.0",
      "@iota/iota-sdk": "1.11.0",
      "ethers": "6.16.0",
      "@coral-xyz/anchor": "0.32.1"
    }
  },
  "toolchains": {
    "node": "23.11.0 (verified; 24+ recommended for @iota/iota-sdk)",
    "bun": "1.3.6",
    "rust": "1.89.0-nightly",
    "anchor_cli": "0.31.1",
    "solana_cli": "2.3.11",
    "foundry": "1.5.0",
    "aptos_cli": "8.1.0",
    "sui_cli": "1.66.2"
  },
  "verification": {
    "source_repo": "../sb-on-demand-examples",
    "last_verified": "2026-03-03",
    "commands": [
      {
        "id": "rust-common",
        "cwd": "common/rust-feed-creation",
        "command": "cargo check"
      },
      {
        "id": "solana-feeds",
        "cwd": "solana/feeds/basic",
        "command": "cargo build-sbf"
      },
      {
        "id": "solana-randomness",
        "cwd": "solana/randomness/coin-flip",
        "command": "cargo build-sbf"
      },
      {
        "id": "solana-prediction-market",
        "cwd": "solana/prediction-market",
        "command": "cargo build-sbf"
      },
      {
        "id": "evm-price-feeds",
        "cwd": "evm/price-feeds",
        "command": "(bun install || npm install) && ([ -d lib/forge-std ] || forge install foundry-rs/forge-std --no-git) && forge build"
      },
      {
        "id": "evm-randomness-coin-flip",
        "cwd": "evm/randomness/coin-flip",
        "command": "(bun install || npm install) && ([ -d lib/forge-std ] || forge install foundry-rs/forge-std --no-git) && forge build"
      },
      {
        "id": "evm-randomness-pancake-stacker",
        "cwd": "evm/randomness/pancake-stacker",
        "command": "(bun install || npm install) && ([ -d lib/forge-std ] || forge install foundry-rs/forge-std --no-git) && forge build"
      },
      {
        "id": "sui-feeds",
        "cwd": "sui/feeds/basic",
        "command": "npm install && npm run build"
      },
      {
        "id": "sui-surge-ts",
        "cwd": "sui/surge/basic",
        "command": "npm install && npx tsc --noEmit"
      },
      {
        "id": "solana-surge-ts",
        "cwd": "solana/surge",
        "command": "npm install && npx tsc --noEmit"
      },
      {
        "id": "solana-x402-ts",
        "cwd": "solana/x402",
        "command": "pnpm install --frozen-lockfile || pnpm install && pnpm exec tsc --noEmit"
      },
      {
        "id": "aptos-smoke",
        "cwd": "/tmp/sb-sdk-smoke/aptos",
        "command": "npm install && npx tsc --noEmit"
      },
      {
        "id": "movement-smoke",
        "cwd": "/tmp/sb-sdk-smoke/movement",
        "command": "npm install && npx tsc --noEmit"
      },
      {
        "id": "iota-smoke",
        "cwd": "/tmp/sb-sdk-smoke/iota",
        "command": "npm install && npx tsc --noEmit"
      }
    ],
    "notes": [
      "@mysten/sui latest (2.x) is not yet compatible with current docs/examples imports; pinned to 1.38.0.",
      "solana/prediction-market build-sbf can fail on edition2024 transitive crates under current Solana toolchain cargo; verify with fallback host cargo check if encountered.",
      "sui/feeds/basic contains an upstream failing Move unit test; treat build/typecheck as the dependency compatibility gate."
    ]
  }
}
